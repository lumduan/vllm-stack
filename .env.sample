# ============================================================
# vllm-stack — Environment Variables
# ============================================================
# คัดลอกไฟล์นี้เป็น .env แล้วแก้ไขค่าให้ตรงกับการตั้งค่าของคุณ
# cp .env.sample .env
# ============================================================

# HuggingFace API Token
# สร้าง token ได้ที่ https://huggingface.co/settings/tokens
# จำเป็นสำหรับโมเดลที่ต้องขอสิทธิ์ก่อนดาวน์โหลด (gated models)
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ชื่อโมเดลจาก HuggingFace ที่ต้องการรัน
# ถ้าไม่กำหนด จะใช้ค่า default ใน docker-compose.yaml
MODEL_NAME=typhoon-ai/typhoon2.5-qwen3-4b
